[Unit]
Description=RASMARA Production Stack (Docker Compose)
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=__REPO_DIR__
ExecStart=/usr/bin/docker compose -f __REPO_DIR__/docker-compose.prod.yml --env-file __REPO_DIR__/.env.prod up -d
ExecStop=/usr/bin/docker compose -f __REPO_DIR__/docker-compose.prod.yml --env-file __REPO_DIR__/.env.prod down
TimeoutStartSec=0
User=__USER__

[Install]
WantedBy=multi-user.target
