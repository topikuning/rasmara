# ============================================================
# RASMARA - environment variables (template)
# ============================================================
#
# CARA PAKAI:
#
#   Untuk DEV lokal (Docker Compose dev di laptop / komputer):
#       cp .env.example .env
#       (Makefile target 'make up' / 'make migrate' / dst. baca dari .env)
#
#   Untuk PRODUCTION di VPS Debian 11:
#       cp .env.example .env.prod
#       (script deploy/debian11/*.sh dan 'make prod-up' baca dari .env.prod)
#
# JANGAN commit .env atau .env.prod ke git — sudah di-ignore via .gitignore.
# Semua nilai SECRET di prod WAJIB di-ganti random (jangan pakai default).

# ---- Mode akses ----
# Kosongkan SITE_ADDRESS untuk akses via IP di port 80 (mode awal).
# Setelah punya domain, isi DOMAIN dan set SITE_ADDRESS=https://<domain>
# Caddy akan otomatis mengambil sertifikat Let's Encrypt.
SITE_ADDRESS=:80
DOMAIN=
ADMIN_EMAIL=admin@rasmara.local

# ---- Django ----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-min-50-chars
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SETTINGS_MODULE=rasmara.settings.prod
DJANGO_TIME_ZONE=Asia/Jakarta
DJANGO_LANGUAGE_CODE=id

# ---- Frontend ----
# URL backend yang dipanggil dari browser. Untuk mode IP/port-80, biarkan kosong
# (frontend akan pakai relative path /api/v1/ via reverse proxy Caddy).
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_APP_NAME=RASMARA
# Internal URL backend dari container frontend (server-side fetch Next.js)
INTERNAL_API_BASE_URL=http://backend:8000

# ---- PostgreSQL ----
POSTGRES_DB=rasmara
POSTGRES_USER=rasmara
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Queue / Redis (opsional, --profile queue) ----
# QUEUE_ENABLED=true hanya bila Anda menjalankan stack dengan --profile queue
# (Redis + Celery worker + Celery beat). Default false untuk VPS kecil.
QUEUE_ENABLED=false
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Gunicorn tuning ----
# 1 worker x 2 threads cukup utk VPS 1 vCPU + 2GB RAM. Naikkan saat di-upgrade.
GUNICORN_WORKERS=1
GUNICORN_THREADS=2

# ---- MinIO (S3 compatible) ----
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=
MINIO_ROOT_USER=rasmara
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=rasmara-media
MINIO_USE_SSL=0

# ---- SMTP (email) ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=0
SMTP_FROM=noreply@rasmara.local

# ---- WhatsApp provider ----
# Pilihan: stub (default, write to log/db only), waha, baileys
WHATSAPP_PROVIDER=stub
WHATSAPP_WAHA_URL=
WHATSAPP_WAHA_TOKEN=

# ---- Initial superadmin (dipakai management command create_superadmin) ----
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_EMAIL=superadmin@rasmara.local

# ---- Host port mappings (DEV only) ----
# Ganti angka di kanan kalau port di host sudah dipakai layanan lain.
# Contoh: HOST_PORT_MAILPIT_UI=8125 jika 8025 sudah dipakai mailpit lokal lain.
# Yang paling penting tetap bisa diakses adalah HOST_PORT_HTTP (Caddy).
HOST_PORT_HTTP=80
HOST_PORT_HTTPS=443
HOST_PORT_FRONTEND=3000
HOST_PORT_BACKEND=8000
HOST_PORT_POSTGRES=5432
HOST_PORT_REDIS=6379
HOST_PORT_MINIO_API=9000
HOST_PORT_MINIO_CONSOLE=9001
HOST_PORT_MAILPIT_SMTP=1025
HOST_PORT_MAILPIT_UI=8025
